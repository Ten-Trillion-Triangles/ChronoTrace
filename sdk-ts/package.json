{
  "name": "@chronotrace/sdk-ts",
  "version": "1.0.0",
  "description": "AI-native temporal logging SDK for TypeScript and JavaScript",
  "main": "dist/src/index.js",
  "module": "dist/src/index.js",
  "browser": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check:contracts": "node ./scripts/check-generated-contracts.mjs",
    "test": "vitest run"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "keywords": [
    "tracing",
    "logging",
    "observability",
    "telemetry",
    "ai-native"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chronotrace/ChronoTrace"
  },
  "bugs": {
    "url": "https://github.com/chronotrace/ChronoTrace/issues"
  }
}
