# ChronoTrace Server — Environment Variables Reference
# Copy this to .env and fill in values. NEVER commit .env to version control.

# =============================================================================
# SERVER BINDING
# =============================================================================

# Host and port the server listens on.
# Default: 127.0.0.1:8080
CHRONOTRACE_BIND_HOST=0.0.0.0
PORT=8080

# =============================================================================
# AUTHENTICATION
# =============================================================================

# Auth mode: none | apiKey | bearer | mTLS
# - none: No auth. Only for local development behind a firewall.
# - apiKey: Clients send X-Api-Key header.
# - bearer: Clients send Authorization: Bearer <token> header.
# - mTLS: Mutual TLS. Requires TLS certificate configuration.
CHRONOTRACE_AUTH_MODE=none

# Comma-separated list of API keys accepted in apiKey mode.
# Generate keys with: openssl rand -hex 32
CHRONOTRACE_API_KEYS=

# Comma-separated list of bearer tokens accepted in bearer mode.
CHRONOTRACE_BEARER_TOKENS=

# TLS configuration (required for mTLS mode, recommended for all non-local deployments)
# Terminate TLS at a reverse proxy or load balancer; the server does not terminate TLS.
# CHRONOTRACE_TLS_CERT_PATH=/etc/chronotrace/server.crt
# CHRONOTRACE_TLS_KEY_PATH=/etc/chronotrace/server.key
# CHRONOTRACE_TLS_CA_PATH=/etc/chronotrace/ca.crt

# =============================================================================
# STORAGE MODE
# =============================================================================

# Storage backend: file | clickhouse
# - file: Local filesystem. Good for local dev. No persistence across restarts unless CHRONOTRACE_DATA_DIR is set.
# - clickhouse: ClickHouse + Valkey. Required for shared/production deployments.
CHRONOTRACE_STORAGE_MODE=file

# Data directory for file mode. Defaults to in-memory if unset.
# CHRONOTRACE_DATA_DIR=/var/chronotrace/data

# =============================================================================
# CLICKHOUSE (required for CHRONOTRACE_STORAGE_MODE=clickhouse)
# =============================================================================

CHRONOTRACE_CLICKHOUSE_JDBC_URL=jdbc:clickhouse://clickhouse:8123/default
CHRONOTRACE_CLICKHOUSE_DATABASE=chronotrace
CHRONOTRACE_CLICKHOUSE_USERNAME=
CHRONOTRACE_CLICKHOUSE_PASSWORD=
CHRONOTRACE_CLICKHOUSE_CONNECT_TIMEOUT_MS=5000

# =============================================================================
# VALKEY (required for CHRONOTRACE_STORAGE_MODE=clickhouse)
# =============================================================================

CHRONOTRACE_VALKEY_HOST=valkey
CHRONOTRACE_VALKEY_PORT=6379
CHRONOTRACE_VALKEY_DATABASE=0
CHRONOTRACE_VALKEY_PASSWORD=
CHRONOTRACE_VALKEY_KEY_PREFIX=chronotrace

# =============================================================================
# RETENTION (applied on every ingest; records older than this are pruned)
# =============================================================================

# Log retention in days. 0 = no pruning. Default: 30.
CHRONOTRACE_RETENTION_LOGS_DAYS=30

# Span retention in days. 0 = no pruning. Default: 30.
CHRONOTRACE_RETENTION_SPANS_DAYS=30

# Frame snapshot retention in days. 0 = no pruning. Default: 7.
CHRONOTRACE_RETENTION_FRAMES_DAYS=7