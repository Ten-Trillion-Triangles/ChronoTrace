# =============================================================================
# ChronoTrace Server — Environment Variable Reference
# =============================================================================
# Copy this file to .env and fill in your values. The server reads these at
# startup. Never commit .env with real secrets — keep .env in .gitignore.
# =============================================================================

# --- Server binding ------------------------------------------------------------
# Host to bind to. Use 0.0.0.0 in containers/Docker; 127.0.0.1 for local-only.
CHRONOTRACE_BIND_HOST=127.0.0.1

# HTTP server port (default: 8080)
PORT=8080

# --- Authentication ------------------------------------------------------------
# Auth mode: "none" (local/no auth), "apiKey" (X-Api-Key header), or "bearer" (Authorization: Bearer).
# WARNING: "none" exposes the server to anyone with network access.
CHRONOTRACE_AUTH_MODE=none

# Comma-separated list of API keys (used when CHRONOTRACE_AUTH_MODE=apiKey).
# Generate a key: openssl rand -hex 32
CHRONOTRACE_API_KEYS=

# Comma-separated list of bearer tokens (used when CHRONOTRACE_AUTH_MODE=bearer).
# Generate tokens: openssl rand -hex 32
CHRONOTRACE_BEARER_TOKENS=

# --- Storage mode --------------------------------------------------------------
# "FILE" or "CLICKHOUSE". Defaults to FILE if unset.
CHRONOTRACE_STORAGE_MODE=FILE

# Path to directory for file-mode storage (stores chronotrace_store.json).
# Defaults to in-memory if unset.
# CHRONOTRACE_DATA_DIR=/var/chronotrace/data

# --- Retention (days) ----------------------------------------------------------
# TTL for log records. Older records are pruned on every ingest.
# 0 = disabled. Default: 30
CHRONOTRACE_RETENTION_LOGS_DAYS=30

# TTL for span records.
# 0 = disabled. Default: 30
CHRONOTRACE_RETENTION_SPANS_DAYS=30

# TTL for frame snapshots (shorter because they're large).
# 0 = disabled. Default: 7
CHRONOTRACE_RETENTION_FRAMES_DAYS=7

# --- ClickHouse ----------------------------------------------------------------
# JDBC URL for ClickHouse (required when CHRONOTRACE_STORAGE_MODE=CLICKHOUSE).
CHRONOTRACE_CLICKHOUSE_JDBC_URL=jdbc:clickhouse://clickhouse:8123/default

# ClickHouse database name (created automatically on startup if it doesn't exist).
CHRONOTRACE_CLICKHOUSE_DATABASE=chronotrace

# Optional ClickHouse credentials.
# CHRONOTRACE_CLICKHOUSE_USERNAME=
# CHRONOTRACE_CLICKHOUSE_PASSWORD=

# JDBC connection timeout in milliseconds. Default: 5000
CHRONOTRACE_CLICKHOUSE_CONNECT_TIMEOUT_MS=5000

# Bounded ingest queue — protects ClickHouse from backpressure spikes.
# When set to 0 (default), writes are synchronous (no queue).
# Set to a positive value (e.g. 100–500) to enable async queueing with circuit breaker.
CHRONOTRACE_CLICKHOUSE_INGEST_QUEUE_CAPACITY=0

# Timeout in milliseconds for waiting to enqueue a batch.
# If the queue is full, the server returns HTTP 503 "circuit breaker open".
# Default: 5000
CHRONOTRACE_CLICKHOUSE_INGEST_QUEUE_TIMEOUT_MS=5000

# Enable async insert for ClickHouse. When true, batches are inserted asynchronously
# with fire-and-forget semantics. Improves throughput but may lose data on crash.
# Default: false
CHRONOTRACE_CLICKHOUSE_ASYNC_INSERT=false

# Timeout in milliseconds for ClickHouse async insert flush.
# Default: 10000
CHRONOTRACE_CLICKHOUSE_ASYNC_INSERT_TIMEOUT_MS=10000

# Bounce (reject) ingest batches when ClickHouse returns a rejected status.
# When false, rejected batches are silently dropped. When true, returns 503 to the client.
# Default: false
CHRONOTRACE_BOUNCE_ON_REJECTED=false

# --- Valkey --------------------------------------------------------------------
# Valkey host (required when using ClickHouse storage — used for real-time query index).
CHRONOTRACE_VALKEY_HOST=valkey

# Valkey port. Default: 6379
CHRONOTRACE_VALKEY_PORT=6379

# Valkey DB index. Default: 0
CHRONOTRACE_VALKEY_DATABASE=0

# Optional Valkey password.
# CHRONOTRACE_VALKEY_PASSWORD=

# Prefix for all Valkey keys. Allows multiple ChronoTrace instances to share a Valkey cluster.
CHRONOTRACE_VALKEY_KEY_PREFIX=chronotrace